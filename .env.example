# --- NVIDIA NIM (proxy upstream) ---
# Free key from https://build.nvidia.com — no credit card required.
NVIDIA_NIM_API_KEY=nvapi-replace-me

# --- LiteLLM proxy ---
# Bearer key the agent uses to authenticate to the proxy. Generate any
# random string for local/dev use, e.g. `openssl rand -hex 32`.
PROXY_MASTER_KEY=sk-replace-me

# --- Agent <-> proxy wiring ---
# Inside docker-compose these point at the proxy service name; for a
# host-side run (Step 1/2 of the implementation plan) use http://localhost:4000.
ANTHROPIC_BASE_URL=http://proxy:4000
ANTHROPIC_AUTH_TOKEN=sk-replace-me
AGENT_MODEL=claude-sonnet-4-6
AGENT_FALLBACK_MODEL=claude-haiku-4-5
AGENT_PERMISSION_MODE=bypassPermissions
AGENT_MAX_TURNS=40
AGENT_CWD=/workspace
VERIFY_TIMEOUT_MS=120000
VERIFY_MAX_OUTPUT_CHARS=4000

# --- Git credentials injected at container startup ---
GIT_USER_NAME=nim-self-verifying-agent
GIT_USER_EMAIL=agent@example.invalid
# Scoped to a single repo, minimal permissions (contents: write).
GITHUB_TOKEN=ghp_replace-me

# Optional: host UID/GID so files written into the mounted workspace
# aren't root-owned. Run `id -u`/`id -g` on the host to get these.
HOST_UID=1000
HOST_GID=1000
